generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  avatar        String?
  company       String?
  role          String   @default("user") // user, admin
  language      String   @default("ru")
  emailFrom     String?  // custom sender email for mailings (e.g. info@mysalon.com)
  vapiApiKey    String?  // Vapi.ai API key for AI voice calls
  vapiPhoneId   String?  // Vapi.ai phone number ID (purchased in Vapi dashboard)
  vapiPhone     String?  // the actual phone number for display (e.g. +1234567890)
  isActive      Boolean  @default(true)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  Bot             Bot[]
  Subscription    Subscription[]
  AnalyticsEvent  AnalyticsEvent[]
  Payment         Payment[]
  DemoPeriod      DemoPeriod?
  CallLog         CallLog[]
}

model Admin {
  id            String   @id @default(uuid())
  userId        String   @unique
  email         String   @unique
  passwordHash  String
  twoFactorCode String?
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  AdminLog AdminLog[]
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String   // impersonate, block_user, generate_code, revoke_code, etc.
  details   String?  // JSON string
  ipAddress String?
  createdAt DateTime @default(now())

  Admin Admin @relation(fields: [adminId], references: [id])
}

model Subscription {
  id            String   @id @default(uuid())
  userId        String
  plan          String   @default("demo") // demo, monthly, quarterly, yearly, lifetime
  status        String   @default("active") // active, expired, cancelled
  startsAt      DateTime @default(now())
  expiresAt     DateTime?
  autoRenew     Boolean  @default(false)
  pricePaid     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  User      User     @relation(fields: [userId], references: [id])
  Payment   Payment[]
}

model DemoPeriod {
  id         String   @id @default(uuid())
  userId     String   @unique
  startsAt   DateTime @default(now())
  expiresAt  DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  User User @relation(fields: [userId], references: [id])
}

model Bot {
  id          String   @id @default(uuid())
  userId      String
  name        String
  type        String   @default("ai") // ai, rule-based, hybrid
  niche        String?  // salon, medical, restaurant, etc.
  avatar      String?
  config      String   @default("{}") // JSON: greeting, tone, working hours, features, etc.
  appearance  String   @default("{}") // JSON: colors, position, size, etc.
  isActive    Boolean  @default(true)
  embedCode   String?  @unique
  telegramToken String?
  whatsappConfig String?
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  User         User           @relation(fields: [userId], references: [id])
  Conversation Conversation[]
  Appointment Appointment[]
  Lead        Lead[]
}

model BotTemplate {
  id          String   @id @default(uuid())
  niche       String   @unique
  name        String
  description String?
  greeting    String?
  faq         String?  // JSON array
  colors      String?  // JSON object
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(uuid())
  botId     String
  source    String   @default("widget") // widget, telegram, whatsapp
  visitorId String?
  visitorName String?
  status    String   @default("active") // active, closed, archived
  isFlagged Boolean  @default(false)
  isProcessed Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Bot     Bot       @relation(fields: [botId], references: [id])
  Message Message[]
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  role           String   @default("user") // user, bot, operator, system
  content        String
  messageType    String   @default("text") // text, buttons, card, calendar, contact_form
  metadata       String?  // JSON for extra data
  createdAt      DateTime @default(now())

  Conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Appointment {
  id         String   @id @default(uuid())
  botId      String
  visitorName  String
  visitorPhone String
  visitorEmail String?
  service    String?
  date       DateTime
  duration   Int      @default(60) // minutes
  status     String   @default("pending") // pending, confirmed, cancelled, completed
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  Bot Bot @relation(fields: [botId], references: [id])
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String
  botId     String?
  eventType String   // page_view, message_sent, appointment_booked, widget_opened
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  User User @relation(fields: [userId], references: [id])
}

model Payment {
  id            String   @id @default(uuid())
  userId        String
  subscriptionId String?
  amount        Float
  currency      String   @default("USD")
  plan          String
  status        String   @default("pending") // pending, completed, failed, refunded
  provider      String?  // stripe
  providerId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  User         User         @relation(fields: [userId], references: [id])
  Subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

model CallLog {
  id              String   @id @default(uuid())
  userId          String
  botId           String?
  clientPhone     String
  companyPhone    String
  taskDescription String
  script          String   @default("")
  callType        String   @default("custom") // confirmation, reminder, follow_up, custom
  status          String   @default("queued") // queued, ringing, in_progress, completed, failed, no_answer, cancelled
  duration        Int      @default(0) // seconds
  transcript      String   @default("") // JSON array of dialog lines
  aiSummary       String   @default("") // AI-generated short result
  vapiCallId      String?  // Vapi.ai call ID for webhook correlation
  cost            Float?   // call cost in USD from Vapi
  createdAt       DateTime @default(now())

  User User @relation(fields: [userId], references: [id])
}

model EmbedCode {
  id        String   @id @default(uuid())
  botId     String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdBy String?  // admin user id for manual creation
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id           String   @id @default(uuid())
  botId        String
  visitorName  String?
  visitorPhone String?
  visitorEmail String?
  ipAddress    String?
  region       String?
  message      String?
  source       String   @default("widget")
  status       String   @default("new")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  Bot Bot @relation(fields: [botId], references: [id])
}
